includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - plugin.php
        - uninstall.php
        - src
    bootstrapFiles:
        - src/autoload.php
    ignoreErrors:
        # The WordPress AI Client (WordPress\AiClient\*) ships with WordPress 7.0
        # and is not a Composer dependency of this plugin, so PHPStan cannot see
        # those classes, interfaces, or enums. Ignore errors that reference them.
        - identifier: class.notFound
          message: '#WordPress\\AiClient#'
        - '#WordPress\\AiClient#'
    # Some ignore patterns above may not match on every run (depending on which
    # AI Client symbols are referenced); do not fail the build over that.
    reportUnmatchedIgnoredErrors: false
