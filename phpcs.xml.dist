<?xml version="1.0"?>
<ruleset name="AI Provider for WebLLM">
    <description>Coding standards: PSR-12 plus PHP cross-version compatibility.</description>

    <!-- Scan PHP in the plugin root and src directory. -->
    <file>plugin.php</file>
    <file>uninstall.php</file>
    <file>src</file>

    <!-- Exclude generated and third-party code. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!--
        This plugin uses modern, namespaced PSR-12 PHP (strict types, short array
        syntax, camelCase methods, PSR-4 file names) rather than WordPress-Core
        formatting, so it is linted against PSR-12.
    -->
    <rule ref="PSR12"/>

    <!-- Verify the code stays compatible with the declared minimum PHP version. -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="7.4-"/>

    <!-- Warnings (plugin-file side effects, a few long lines) should not fail CI. -->
    <config name="ignore_warnings_on_exit" value="1"/>
</ruleset>
